# AMI → pAMI Infrastructure Configuration
# Copy to .env and fill in real values.
# NEVER commit .env to version control.

# --- Context7 (library docs MCP) ---
# CONTEXT7=ctx7sk-...

# --- OpenAI ---
# OPENAI_API_KEY=sk-proj-...
# OPENAI_MODEL=gpt-4o

# --- Anthropic ---
# ANTHROPIC_API_KEY=sk-ant-api03-...
# ANTHROPIC_MODEL=claude-sonnet-4-5

# --- xAI (Grok) ---
# XAI_API_KEY=xai-...
# XAI_MODEL=grok-3

# --- Triage behaviour ---
# TRIAGE_ENABLE_STREAMING=false
# TRIAGE_DEFAULT_SIGNIFICANCE_MODE=surrogate

# --- MCP server ---
# MCP_HOST=localhost
# MCP_PORT=8000
